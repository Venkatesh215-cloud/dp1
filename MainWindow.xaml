                                    <TextBlock x:Name="rt_tbError"
                                               Grid.Row="5" Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="Red"
                                               Text="-"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!--═══════════════════════════════════════-->
            <!-- TAB 3 : RT SIMULATOR (NEW!)          -->
            <!--═══════════════════════════════════════-->
            <TabItem Header="RT Simulator  (Required for RT→BC Testing)">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                    <Grid Background="Transparent" Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- ROW 0 : Configuration                                   -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <GroupBox Grid.Row="0"
                      Header="RT Simulator Configuration"
                      BorderBrush="Navy"
                      BorderThickness="2"
                      Margin="3"
                      FontFamily="Lucida Fax"
                      FontSize="14"
                      FontWeight="Bold"
                      Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                            <StackPanel Margin="10">

                                <!-- Warning Banner -->
                                <Border Background="#FFFFF4DC"
                            BorderBrush="#FFFFA500"
                            BorderThickness="2"
                            CornerRadius="4"
                            Padding="10"
                            Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="⚠ IMPORTANT: Start RT Simulator BEFORE using RT→BC tab!"
                                       FontWeight="Bold"
                                       FontFamily="Lucida Fax"
                                       FontSize="13"
                                       Foreground="#FFCC6600"
                                       Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="#FF333333">
                                The DDC card will act as an RT device responding to BC requests.
                                You can update response data LIVE without stopping the simulator.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Config Grid -->
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Device ID -->
                                    <StackPanel Grid.Column="0" Margin="4">
                                        <Label Content="Device ID :"
                                   FontFamily="Lucida Fax"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                                        <TextBox x:Name="rtsim_deviceIdTextBox"
                                     Height="28"
                                     FontSize="13"
                                     Style="{StaticResource WhiteTextBox}"
                                     Text="0"
                                     HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- RT Address -->
                                    <StackPanel Grid.Column="1" Margin="4">
                                        <Label Content="RT Address :"
                                   FontFamily="Lucida Fax"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="rtsim_rtAddressComboBox"
                                      Style="{StaticResource RoundedComboBox}"
                                      Height="28">
                                            <ComboBoxItem Content="1" IsSelected="True"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Sub Address -->
                                    <StackPanel Grid.Column="2" Margin="4">
                                        <Label Content="Sub Address :"
                                   FontFamily="Lucida Fax"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="rtsim_subAddressComboBox"
                                      Style="{StaticResource RoundedComboBox}"
                                      Height="28">
                                            <ComboBoxItem Content="1" IsSelected="True"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="21"/>
                                            <ComboBoxItem Content="22"/>
                                            <ComboBoxItem Content="23"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="25"/>
                                            <ComboBoxItem Content="26"/>
                                            <ComboBoxItem Content="27"/>
                                            <ComboBoxItem Content="28"/>
                                            <ComboBoxItem Content="29"/>
                                            <ComboBoxItem Content="30"/>
                                            <ComboBoxItem Content="31"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Bus -->
                                    <StackPanel Grid.Column="3" Margin="4">
                                        <Label Content="1553 Bus :"
                                   FontFamily="Lucida Fax"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="rtsim_busSelectionComboBox"
                                      Style="{StaticResource RoundedComboBox}"
                                      Height="28">
                                            <ComboBoxItem Content="A" IsSelected="True"/>
                                            <ComboBoxItem Content="B"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Status Badge -->
                                <Border x:Name="rtsim_statusBorder"
                            Background="Gray"
                            CornerRadius="6"
                            Padding="12,6"
                            Margin="4,8,4,4"
                            HorizontalAlignment="Center">
                                    <TextBlock x:Name="rtsim_statusText"
                                   Text="⚫ RT SIMULATOR STOPPED"
                                   FontFamily="Lucida Fax"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                                </Border>

                                <!-- Start / Stop Buttons -->
                                <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="4,6,4,4">
                                    <Button x:Name="rtsim_startButton"
                                Content="▶  Start RT Simulator"
                                Width="180" Height="40"
                                FontSize="13"
                                Margin="6"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_Start_Click"/>
                                    <Button x:Name="rtsim_stopButton"
                                Content="⏹  Stop RT Simulator"
                                Width="180" Height="40"
                                FontSize="13"
                                Margin="6"
                                IsEnabled="False"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_Stop_Click"/>
                                </StackPanel>

                            </StackPanel>
                        </GroupBox>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- ROW 1 : Quick Test Patterns                             -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <GroupBox Grid.Row="1"
                      Header="Quick Test Patterns"
                      BorderBrush="Navy"
                      BorderThickness="2"
                      Margin="3"
                      FontFamily="Lucida Fax"
                      FontSize="14"
                      FontWeight="Bold"
                      Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                            <StackPanel Margin="10">

                                <TextBlock TextWrapping="Wrap"
                               FontFamily="Lucida Fax"
                               FontSize="11"
                               Foreground="#FF444444"
                               Margin="0,0,0,8">
                        Click any pattern to load it into the data box below,
                        then click <Bold>"🔄 Update RT Data"</Bold> to apply it to the running simulator.
                                </TextBlock>

                                <WrapPanel HorizontalAlignment="Left">
                                    <Button Content="Default&#x0a;(1234..89AB)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadDefault_Click"/>
                                    <Button Content="Pattern 1&#x0a;(0001→0020)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadTestData1_Click"/>
                                    <Button Content="Pattern 2&#x0a;(AA55/55AA)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadTestData2_Click"/>
                                    <Button Content="Pattern 3&#x0a;(All 0000)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadTestData3_Click"/>
                                    <Button Content="Pattern 4&#x0a;(All FFFF)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadTestData4_Click"/>
                                    <Button Content="Pattern 5&#x0a;(DEAD/BEEF)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_LoadTestData5_Click"/>
                                    <Button Content="Clear Data&#x0a;(Empty Box)"
                                Width="118" Height="44"
                                FontSize="11"
                                Margin="3"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_ClearData_Click"/>
                                </WrapPanel>

                            </StackPanel>
                        </GroupBox>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- ROW 2 : Manual Data Entry + Live Update                 -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <GroupBox Grid.Row="2"
                      Header="RT Response Data  —  Manual Entry &amp; Live Update"
                      BorderBrush="Navy"
                      BorderThickness="2"
                      Margin="3"
                      FontFamily="Lucida Fax"
                      FontSize="14"
                      FontWeight="Bold"
                      Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                            <StackPanel Margin="10">

                                <!-- Instruction banner -->
                                <Border Background="#FFF0F4FF"
                            BorderBrush="#FFAABBDD"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,7"
                            Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                       Text="📝"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="How to enter data manually:"
                                           FontFamily="Lucida Fax"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,3"/>
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax"
                                           FontSize="11"
                                           Foreground="#FF333333">
                                    Type HEX words (4 hex digits each) separated by spaces in the box below.
                                    Example:  <Bold>1234 5678 ABCD EF01</Bold>
                                    Up to 32 words maximum.  Then click  <Bold>"🔄 Update RT Data"</Bold>.
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Word count display -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="Enter HEX data below (space-separated, max 32 words):"
                                   FontFamily="Lucida Fax"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBlock Text="Words: "
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                                        <TextBlock x:Name="rtsim_wordCountLabel"
                                       Text="32"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="Navy"
                                       VerticalAlignment="Center"/>
                                        <TextBlock Text=" / 32"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ── MAIN DATA ENTRY TEXTBOX ── -->
                                <TextBox x:Name="rtsim_responseDataTextBox"
                             FontSize="14"
                             FontFamily="Courier New"
                             Height="110"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             AcceptsTab="False"
                             HorizontalAlignment="Stretch"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource WhiteTextBox}"
                             ToolTip="Type 4-digit HEX words separated by spaces. Max 32 words."
                             TextChanged="RTSim_DataTextBox_TextChanged"
                             Text="1234 5678 ABCD EF01 2345 6789 BCDE F012 3456 789A CDEF 0123 4567 89AB CDEF 0123 4567 89AB CDEF 0123 4567 89AB CDEF 0123 4567 89AB CDEF 0123 4567 89AB"/>

                                <!-- Validation status row -->
                                <Border x:Name="rtsim_validationBorder"
                            Background="#FFE8F5E9"
                            BorderBrush="#FF4CAF50"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,3"
                            Margin="0,4,0,0">
                                    <TextBlock x:Name="rtsim_validationText"
                                   Text="✔ Data looks valid — ready to update."
                                   FontFamily="Lucida Fax"
                                   FontSize="11"
                                   Foreground="#FF2E7D32"/>
                                </Border>

                                <!-- Update Button Row -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Hint text -->
                                    <Border Grid.Column="0"
                                Background="#FFFFF8E1"
                                BorderBrush="#FFFFCC02"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,6"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                                        <TextBlock TextWrapping="Wrap"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="#FF5D4037">
                                <Bold>Workflow:</Bold>&#x0a;
                                1. Type / paste / select pattern above&#x0a;
                                2. Click <Bold>"🔄 Update RT Data"</Bold>&#x0a;
                                3. Go to RT→BC tab and Receive — new data will appear
                                        </TextBlock>
                                    </Border>

                                    <!-- UPDATE BUTTON -->
                                    <Button x:Name="rtsim_updateDataButton"
                                Grid.Column="1"
                                Content="🔄 Update RT Data&#x0a;      (Live)"
                                Width="170" Height="55"
                                FontSize="14"
                                FontWeight="Bold"
                                IsEnabled="False"
                                Margin="0"
                                Style="{StaticResource RoundedButton}"
                                Click="RTSim_UpdateData_Click"/>
                                </Grid>

                            </StackPanel>
                        </GroupBox>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- ROW 3 : How-To Instructions                             -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <GroupBox Grid.Row="3"
                      Header="How to Use RT Simulator"
                      BorderBrush="Navy"
                      BorderThickness="2"
                      Margin="3"
                      FontFamily="Lucida Fax"
                      FontSize="14"
                      FontWeight="Bold"
                      Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                            <StackPanel Margin="10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left column -->
                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="▶  Setup &amp; Start"
                                       FontFamily="Lucida Fax"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="Navy"
                                       Margin="0,0,0,6"/>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>1.</Bold>  Set Device ID (usually 0)
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>2.</Bold>  Choose RT Address and Sub Address
                                    (must match the RT→BC tab settings)
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>3.</Bold>  Select Bus A or B
                                    (must match BC tab bus selection)
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>4.</Bold>  Type HEX data manually OR
                                    click a Quick Test Pattern button
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>5.</Bold>  Click
                                    <Bold>"▶ Start RT Simulator"</Bold>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Right column -->
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="▶  Test &amp; Update Live"
                                       FontFamily="Lucida Fax"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="Navy"
                                       Margin="0,0,0,6"/>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>6.</Bold>  Go to <Bold>"RT → BC"</Bold> tab
                                    → click <Bold>"Receive Data From RT"</Bold>
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>7.</Bold>  Change data: type new HEX values
                                    OR pick a pattern, then click
                                    <Bold>"🔄 Update RT Data"</Bold>
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>8.</Bold>  Receive again — NEW data appears.
                                    Repeat steps 7-8 for each test.
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFF5F5FF" BorderBrush="#FFAAAACC"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,4">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax" FontSize="11">
                                    <Bold>9.</Bold>  Click
                                    <Bold>"⏹ Stop RT Simulator"</Bold>
                                    when all testing is done
                                            </TextBlock>
                                        </Border>

                                        <Border Background="#FFE8F5E9"
                                    BorderBrush="#FF4CAF50"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,4,0,0">
                                            <TextBlock TextWrapping="Wrap"
                                           FontFamily="Lucida Fax"
                                           FontSize="11"
                                           Foreground="#FF2E7D32">
                                    <Bold>✔ Note:</Bold>  DDC card acts as BOTH BC and RT
                                    simultaneously (RTMT mode).
                                    No external RT hardware needed.
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </GroupBox>

                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!--═══════════════════════════════════════════════════-->
        <!-- ROW 3 : Command Log Panel                        -->
        <!--═══════════════════════════════════════════════════-->
        <GroupBox Grid.Row="3"
                  Header="Command Log"
                  BorderBrush="Navy"
                  BorderThickness="2"
                  Margin="4,2"
                  FontFamily="Lucida Fax"
                  FontSize="13"
                  FontWeight="Bold"
                  Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="logListBox"
                         Grid.Column="0"
                         Background="#FFF5F5DC"
                         Foreground="Black"
                         FontFamily="Courier New"
                         FontSize="12"
                         Style="{StaticResource RoundedListBox}"
                         Margin="4"/>

                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            Margin="4">
                    <Button Content="Save Log"
                            Height="30"
                            Margin="0,0,0,4"
                            Style="{StaticResource RoundedButton}"
                            Click="SaveLog_Click"/>
                    <Button Content="Clear Log"
                            Height="30"
                            Margin="0,0,0,0"
                            Style="{StaticResource RoundedButton}"
                            Click="ClearLog_Click"/>
                </StackPanel>

            </Grid>
        </GroupBox>

        <!--═══════════════════════════════════════════════════-->
        <!-- ROW 4 : Bottom Status Bar                        -->
        <!--═══════════════════════════════════════════════════-->
        <Border Grid.Row="4" Background="#FF002D59">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0">
                <TextBlock x:Name="statusBarText"
                           Text="Ready"
                           Foreground="White"
                           FontFamily="Lucida Fax"
                           FontSize="12"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
