<Window x:Class="DPU.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="1553 Bus Controller Test System"
        Height="820"
        Width="1200" WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#FFE8EDF2">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!--═══════════════════════════════════════════════════-->
        <!-- ROW 0 : Title Bar                                -->
        <!--═══════════════════════════════════════════════════-->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF002D59" Offset="0.0"/>
                    <GradientStop Color="#FF4A87C1" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <TextBlock Text="MIL-STD-1553 Bus Controller Test System"
                       FontSize="20"
                       FontFamily="Lucida Fax"
                       FontWeight="UltraBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!--═══════════════════════════════════════════════════-->
        <!-- ROW 1 : Status LED Bar                           -->
        <!--═══════════════════════════════════════════════════-->
        <Grid Grid.Row="1" Background="#FFD0D8E4">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="10,0">
                <TextBlock Text="1553 Bus Status :"
                           FontFamily="Lucida Fax"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <Ellipse x:Name="ledEllipse"
                         Width="16" Height="16"
                         Fill="Gray"
                         Stroke="Black"
                         StrokeThickness="1"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                <TextBlock x:Name="ledStatusText"
                           Text="Not Connected"
                           FontFamily="Lucida Fax"
                           FontSize="12"
                           Foreground="DimGray"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <Border x:Name="modeBadge"
                        Background="Gray"
                        CornerRadius="4"
                        Padding="8,2"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="modeText"
                               Text="IDLE"
                               FontFamily="Lucida Fax"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="White"/>
                </Border>
            </StackPanel>
        </Grid>

        <!--═══════════════════════════════════════════════════-->
        <!-- ROW 2 : Tab Control                              -->
        <!--═══════════════════════════════════════════════════-->
        <TabControl Grid.Row="2"
                    x:Name="mainTabControl"
                    Margin="4"
                    FontFamily="Lucida Fax"
                    FontSize="13"
                    FontWeight="Bold"
                    Background="#FFE8EDF2"
                    BorderBrush="Navy">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder"
                                        Background="#FF002D59"
                                        CornerRadius="6,6,0,0"
                                        Padding="16,6"
                                        Margin="2,0,2,0">
                                    <ContentPresenter
                                        ContentSource="Header"
                                        TextBlock.Foreground="White"
                                        TextBlock.FontWeight="Bold"
                                        TextBlock.FontFamily="Lucida Fax"
                                        TextBlock.FontSize="13"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder"
                                                Property="Background"
                                                Value="#FF4A87C1"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tabBorder"
                                                Property="Background"
                                                Value="#FF3A6EA0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <!--═══════════════════════════════════════-->
            <!-- TAB 1 : BC to RT                     -->
            <!--═══════════════════════════════════════-->
            <TabItem Header="BC → RT  (Send to Remote Terminal)">
                <Grid Background="Transparent" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ════════════════════════════════════════════════ -->
                    <!--  LEFT COLUMN  –  All Three Builders             -->
                    <!-- ════════════════════════════════════════════════ -->
                    <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- ══════════════════════════════════════ -->
                            <!--  COMMON SETTINGS                      -->
                            <!-- ══════════════════════════════════════ -->
                            <GroupBox Header="Common Settings"
                          BorderBrush="Navy"
                          BorderThickness="2"
                          Margin="3"
                          FontFamily="Lucida Fax"
                          FontSize="13"
                          FontWeight="Bold"
                          Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                                <StackPanel Margin="6">

                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <Label Content="1553 Bus :"
                                   Width="160"
                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="bc_busSelectionComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}">
                                            <ComboBoxItem IsSelected="True">A</ComboBoxItem>
                                            <ComboBoxItem>B</ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <Label Content="Device ID :"
                                   Width="160"
                                   VerticalAlignment="Center"/>
                                        <TextBox x:Name="bc_deviceIdNumber"
                                     Width="70" Height="25"
                                     FontSize="13"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource WhiteTextBox}"
                                     Text="0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <Label Content="RT Address :"
                                   Width="160"
                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="bc_rtAddressComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_rtAddressComboBox_SelectionChanged">
                                            <ComboBoxItem IsSelected="True" Content="1"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="21"/>
                                            <ComboBoxItem Content="22"/>
                                            <ComboBoxItem Content="23"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="25"/>
                                            <ComboBoxItem Content="26"/>
                                            <ComboBoxItem Content="27"/>
                                            <ComboBoxItem Content="28"/>
                                            <ComboBoxItem Content="29"/>
                                            <ComboBoxItem Content="30"/>
                                            <ComboBoxItem Content="31"/>
                                        </ComboBox>
                                    </StackPanel>

                                </StackPanel>
                            </GroupBox>

                            <!-- ══════════════════════════════════════ -->
                            <!--  BUILDER 1 : 32-BIT (Gain + BW)      -->
                            <!-- ══════════════════════════════════════ -->
                            <GroupBox Header="① 32-bit Word  ▸  Gain TC (24-bit) + Bandwidth (8-bit)"
                          BorderBrush="#FF003D99"
                          BorderThickness="2"
                          Margin="3"
                          FontFamily="Lucida Fax"
                          FontSize="13"
                          FontWeight="Bold"
                          Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                                <StackPanel Margin="8">

                                    <!-- Info -->
                                    <Border Background="#FFEFF6FF"
                                BorderBrush="#FF4A87C1"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,4"
                                Margin="0,0,0,8">
                                        <TextBlock FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="#FF002D59"
                                       TextWrapping="Wrap">
                                <Bold>32-bit Layout:</Bold>
                                Bits[31:8] = Gain TC (24-bit)  |  Bits[7:0] = Bandwidth (8-bit)&#x0a;
                                Sent as 2 × 16-bit words:  Word1 = High 16-bit  |  Word2 = Low 16-bit
                                        </TextBlock>
                                    </Border>

                                    <!-- Sub Address -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Sub Address :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_subAddressComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_subAddressComboBox_SelectionChanged">
                                            <ComboBoxItem IsSelected="True" Content="1"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="21"/>
                                            <ComboBoxItem Content="22"/>
                                            <ComboBoxItem Content="23"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="25"/>
                                            <ComboBoxItem Content="26"/>
                                            <ComboBoxItem Content="27"/>
                                            <ComboBoxItem Content="28"/>
                                            <ComboBoxItem Content="29"/>
                                            <ComboBoxItem Content="30"/>
                                            <ComboBoxItem Content="31"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Gain ComboBox – shows only dBm value -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Gain (dBm) :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_gainComboBox"
                                      Width="120"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_gainComboBox_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Bandwidth ComboBox – shows only KHz -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Bandwidth :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_bandwidthComboBox"
                                      Width="120"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_bandwidthComboBox_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Word Count -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Word Count :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_wordCountComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_wordCountComboBox_SelectionChanged">
                                            <ComboBoxItem Content="2" IsSelected="True"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="32"/>
                                        </ComboBox>
                                        <TextBlock Text=" 16-bit words"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       Margin="6,0"/>
                                    </StackPanel>

                                    <!-- TX Message Box -->
                                    <Label Content="TX Message (32-bit Hex Words) :"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                                    <TextBox x:Name="bc_txMessageTextBox"
                                 FontSize="12"
                                 Height="46"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 HorizontalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource WhiteTextBox}"
                                 FontFamily="Courier New"/>

                                    <!-- Hidden labels needed by code-behind -->
                                    <TextBlock x:Name="bc_gainBitsLabel"   Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_bwBitsLabel"     Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_32bitHexPreview" Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_word1HexLabel"   Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_word2HexLabel"   Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_gainHexLabel"    Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_bwHexLabel"      Visibility="Collapsed"/>

                                    <!-- Send + Clear Buttons -->
                                    <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8">
                                        <Button Content="▶ Send 32-bit"
                                    Width="140" Height="36"
                                    FontSize="13" Margin="4"
                                    Style="{StaticResource RoundedButton}"
                                    Click="BC_Send32Bit_Click"/>
                                        <Button Content="Clear All"
                                    Width="100" Height="36"
                                    FontSize="13" Margin="4"
                                    Style="{StaticResource RoundedButton}"
                                    Click="BC_Clear_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </GroupBox>

                            <!-- ══════════════════════════════════════ -->
                            <!--  BUILDER 2 : 8-BIT (Power Limit)     -->
                            <!-- ══════════════════════════════════════ -->
                            <GroupBox Header="② 8-bit Word  ▸  Power Limit"
                          BorderBrush="#FF8B0000"
                          BorderThickness="2"
                          Margin="3"
                          FontFamily="Lucida Fax"
                          FontSize="13"
                          FontWeight="Bold"
                          Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                                <StackPanel Margin="8">

                                    <!-- Info -->
                                    <Border Background="#FFFFF0F0"
                                BorderBrush="#FFDDAABB"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,4"
                                Margin="0,0,0,8">
                                        <TextBlock FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="#FF8B0000"
                                       TextWrapping="Wrap">
                                <Bold>8-bit Layout:</Bold>
                                Bits[7:0] = Power Limit register value&#x0a;
                                Sent as 1 × 16-bit word (padded):  0x00XX
                                        </TextBlock>
                                    </Border>

                                    <!-- Sub Address -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Sub Address :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_pwrSubAddressComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}">
                                            <ComboBoxItem IsSelected="True" Content="1"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="21"/>
                                            <ComboBoxItem Content="22"/>
                                            <ComboBoxItem Content="23"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="25"/>
                                            <ComboBoxItem Content="26"/>
                                            <ComboBoxItem Content="27"/>
                                            <ComboBoxItem Content="28"/>
                                            <ComboBoxItem Content="29"/>
                                            <ComboBoxItem Content="30"/>
                                            <ComboBoxItem Content="31"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Power Limit ComboBox – shows only dBm number -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Power Limit (dBm) :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_powerLimitComboBox"
                                      Width="100"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_powerLimitComboBox_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Word Count -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Word Count :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_pwrWordCountComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_pwrWordCountComboBox_SelectionChanged">
                                            <ComboBoxItem Content="1" IsSelected="True"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="8"/>
                                        </ComboBox>
                                        <TextBlock Text=" 16-bit words"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       Margin="6,0"/>
                                    </StackPanel>

                                    <!-- Hidden labels needed by code-behind -->
                                    <TextBlock x:Name="bc_pwrBitsLabel"    Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_pwrWordHexLabel" Visibility="Collapsed"/>
                                    <TextBlock x:Name="bc_pwrByteHexLabel" Visibility="Collapsed"/>

                                    <!-- TX Message Box -->
                                    <Label Content="TX Message (Power Limit Hex Word) :"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                                    <TextBox x:Name="bc_pwrTxMessageTextBox"
                                 FontSize="12"
                                 Height="34"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 HorizontalAlignment="Stretch"
                                 Style="{StaticResource WhiteTextBox}"
                                 FontFamily="Courier New"/>

                                    <!-- Send Button -->
                                    <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8">
                                        <Button Content="▶ Send 8-bit Power Limit"
                                    Width="200" Height="36"
                                    FontSize="13" Margin="4"
                                    Style="{StaticResource RoundedButton}"
                                    Click="BC_Send8BitPower_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </GroupBox>

                            <!-- ══════════════════════════════════════════ -->
                            <!--  BUILDER 3 : 24-BIT Gain TC Sequential    -->
                            <!-- ══════════════════════════════════════════ -->
                            <GroupBox Header="③ 24-bit Word  ▸  Gain TC Sequential Send"
                          BorderBrush="#FF6A0DAD"
                          BorderThickness="2"
                          Margin="3"
                          FontFamily="Lucida Fax"
                          FontSize="13"
                          FontWeight="Bold"
                          Style="{StaticResource RoundedGroupBoxWithWhiteHeader}">
                                <StackPanel Margin="8">

                                    <!-- Info -->
                                    <Border Background="#FFF8F0FF"
                                BorderBrush="#FFCC99FF"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,4"
                                Margin="0,0,0,8">
                                        <TextBlock FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="#FF4B0082"
                                       TextWrapping="Wrap">
                                <Bold>24-bit Sequential Send:</Bold>
                                Select a gain mode then click 'Send Sequential'.&#x0a;
                                Each TC value is sent as 2 × 16-bit words automatically.
                                        </TextBlock>
                                    </Border>

                                    <!-- Sub Address -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Sub Address :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_gainTcSubAddressComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}">
                                            <ComboBoxItem IsSelected="True" Content="1"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="21"/>
                                            <ComboBoxItem Content="22"/>
                                            <ComboBoxItem Content="23"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="25"/>
                                            <ComboBoxItem Content="26"/>
                                            <ComboBoxItem Content="27"/>
                                            <ComboBoxItem Content="28"/>
                                            <ComboBoxItem Content="29"/>
                                            <ComboBoxItem Content="30"/>
                                            <ComboBoxItem Content="31"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Gain Mode -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Gain Mode :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_gainTcModeComboBox"
                                      Width="240"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_gainTcModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="-55  →  0 to +45 dBm  (46 steps)"
                                              Tag="-55"/>
                                            <ComboBoxItem Content="-26  →  -22 to +22 dBm  (45 steps)"
                                              Tag="-26"/>
                                            <ComboBoxItem Content="-10  →  -45 to 0 dBm  (46 steps)"
                                              Tag="-10"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Word Count -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Word Count :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_gainTcWordCountComboBox"
                                      Width="70"
                                      Style="{StaticResource RoundedComboBox}"
                                      SelectionChanged="bc_gainTcWordCountComboBox_SelectionChanged">
                                            <ComboBoxItem Content="2" IsSelected="True"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="8"/>
                                        </ComboBox>
                                        <TextBlock Text=" words per message"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       Margin="6,0"/>
                                    </StackPanel>

                                    <!-- Delay -->
                                    <StackPanel Orientation="Horizontal" Margin="4,3">
                                        <Label Content="Delay (ms) :"
                                   Width="160"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                                        <ComboBox x:Name="bc_gainTcDelayComboBox"
                                      Width="100"
                                      Style="{StaticResource RoundedComboBox}">
                                            <ComboBoxItem Content="100"/>
                                            <ComboBoxItem Content="200"/>
                                            <ComboBoxItem Content="500" IsSelected="True"/>
                                            <ComboBoxItem Content="1000"/>
                                            <ComboBoxItem Content="2000"/>
                                        </ComboBox>
                                        <TextBlock Text=" between sends"
                                       FontFamily="Lucida Fax"
                                       FontSize="11"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       Margin="6,0"/>
                                    </StackPanel>

                                    <!-- Progress -->
                                    <Border Background="#FF180028"
                                CornerRadius="4"
                                Padding="8,6"
                                Margin="0,8,0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,6">
                                                <TextBlock Text="Progress : "
                                               FontFamily="Courier New"
                                               FontSize="11"
                                               Foreground="#FF888888"
                                               VerticalAlignment="Center"/>
                                                <TextBlock x:Name="bc_gainTcCurrentStepLabel"
                                               Text="0"
                                               FontFamily="Courier New"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#FFDDAAFF"
                                               VerticalAlignment="Center"/>
                                                <TextBlock Text="  /  "
                                               FontFamily="Courier New"
                                               FontSize="11"
                                               Foreground="#FF888888"
                                               VerticalAlignment="Center"/>
                                                <TextBlock x:Name="bc_gainTcTotalStepsLabel"
                                               Text="0"
                                               FontFamily="Courier New"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                                <TextBlock Text="  steps"
                                               FontFamily="Courier New"
                                               FontSize="11"
                                               Foreground="#FF888888"
                                               VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="bc_gainTcProgressBar"
                                             Height="14"
                                             Minimum="0"
